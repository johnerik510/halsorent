const faqItems = [
  { q: 'Varför är källarfukt vanligt i Sverige?', a: 'Svenska hus byggda före 1975 saknar ofta ångspärr och fuktisolering mot grundmurarna. Klimatskifte med mer regn och mildare vintrar ökar också grundvattennivåer och tjällyftning, vilket ökar trycket mot grunden.' },
  { q: 'Kan källarfukt påverka inomhusluften i övervåningen?', a: 'Ja. Luften i huset rör sig uppåt (stack-effekt). Mögel och mögelsporer från en fuktig källare sprids till resten av huset via sprickor, ledningsdragningar och öppna dörrar.' },
  { q: 'Hur snabbt växer mögel vid hög källarfukt?', a: 'Vid luftfuktighet över 70 procent och temperaturer 15 till 25 grader kan mögel etablera sig på organiska material (trä, papp, kartong) inom 24 till 72 timmar. Håll källaren under 60 procent för att hämma tillväxt.' },
  { q: 'Är avfuktare en permanent lösning?', a: 'Nej. En avfuktare hanterar symptomet men inte orsaken. Om källaren är fuktig pga. markfukt, otät grundmur eller dålig dränering måste grundorsaken åtgärdas, annars kör du avfuktaren i all oändlighet.' },
  { q: 'Vad kostar det att dränera om ett hus?', a: 'Utvändig dränering: 100 000 till 300 000 kronor beroende på hustyp och svårighetsgrad. Det är en stor investering men enda permanenta lösningen vid grund- eller markfuktsproblem.' },
];
---
<ArticleLayout
  title="Fukt i källaren: orsaker och åtgärder | Hälsorent"
  description="Källarfukt är vanligt i svenska hus och kan orsaka mögel och dålig inomhusluft i hela huset. Vad du kan göra själv och när du behöver en specialist."
  heroImage="/images/articles/kallare.webp"
  heroAlt="Källare med fuktig betongvägg och kondensation som tyder på fuktproblem"
  publishDate="2026-04-29"
