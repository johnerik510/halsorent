const toc = [
  { id: 'varfor-citronsyra', label: 'Varför citronsyra?' },
  { id: 'avkalkning', label: 'Avkalkning steg för steg' },
  { id: 'diskmaskin', label: 'Diskmaskin' },
  { id: 'tvattmaskin', label: 'Tvättmaskin' },
  { id: 'dusch', label: 'Duschkabin och kranar' },
