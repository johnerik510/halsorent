const toc = [
  { id: 'grundregeln', label: 'Grundregeln: uppifrån och ner' },
  { id: 'torrt-fore-vatt', label: 'Torrt före vått' },
  { id: 'rum-for-rum', label: 'Rum för rum' },
  { id: 'vanliga-misstag', label: 'Vanliga misstag' },
  { id: 'faq', label: 'Vanliga frågor' },
];

const faqItems = [
  { q: 'Varför ska man dammsuga efter att man dammtorkat?', a: 'Dammtorkning skapar ett luftflöde som kan uppvira lätta dammpartiklar. Om du dammsuger efter dammtorkning fångar du upp allt som hamnat på golvet. Gör du det omvänt (dammsug sedan dammtorka) sprider du fortfarande gammalt damm neråt, och det hamnar på det rena golvet.' },
  { q: 'Ska jag städa köket eller badrummet först?', a: 'Badrummet. Toaletten är den smutsigaste ytan i hemmet. Städa den tidigt i sessionen, och tvätta händerna noggrant efteråt. Köket städas bäst sist bland rummen, då du naturligt avslutar med att torka av bänkytor och golvet.' },
  { q: 'Kan jag städa på ett städ för att spara tid?', a: 'Ja, det är ofta mer effektivt att göra samma uppgift i alla rum på en gång. Dammtorka alla rum, sedan gå tillbaka och dammsug alla rum. Det minskar kontextsbyten och är snabbare totalt sett.' },
  { q: 'Hur hanterar jag städning när jag har bråttom?', a: 'Prioritera: badrum och kök är alltid viktigast ur hälsosynpunkt (bakterier, mögel). Sovrum är viktigt för allergiern. Vardagsrum kan vänta längre. Se guiden om att städa fort för ett effektivt snabbstädningsschema.' },
  { q: 'Ska jag städa med eller mot solen?', a: 'Med solen, det vill säga bakifrån framåt med tanke på ljusinsläppet. På det sättet ser du damm och smuts bättre och missar inte fläckar.' },
];
---
<ArticleLayout
