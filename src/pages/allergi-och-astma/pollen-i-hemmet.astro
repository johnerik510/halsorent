const faqItems = [
  { q: 'När är pollensäsongen i Sverige?', a: 'Björkpollen: april till maj. Grässläktet: juni till juli. Gråbo: juli till september. De mest besvärliga säsongerna för de flesta pollenkänsliga är april till maj (björk) och juni till juli (gräs).' },
  { q: 'Hur länge dröjer pollen kvar i hemmet?', a: 'Pollen som fastnat i textilier, mattor och möbler kan sitta kvar i veckor om det inte aktivt avlägsnas. Dammsugning med HEPA-filter och tvätt av sängkläder är de effektivaste metoderna.' },
  { q: 'Hjälper luftrenare mot pollen?', a: 'Ja. En luftrenare med HEPA H13-filter fångar pollenpartiklar effektivt. Välj en modell med rätt kapacitet för rumsytan och placera den i sovrummet för bästa effekt under natten.' },
  { q: 'Ska jag stänga alla fönster under pollensäsongen?', a: 'Under pollentoppar (varma, torra och blåsiga dagar) bör fönster hållas stängda. Lufta tidigt på morgonen (före 10:00) eller efter regn, då pollenkoncentrationen är lägre.' },
