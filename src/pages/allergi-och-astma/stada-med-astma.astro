const faqItems = [
  { q: 'Kan jag dammsuga när jag har astma?', a: 'Ja, med rätt utrustning. Använd en dammsugare med H13-filter och tät konstruktion. Lämna rummet i 20 minuter efter dammsugning, så att uppvirvlat damm hinner sätta sig. Ta astmamedicin preventivt om din läkare rekommenderat det.' },
  { q: 'Vilka rengöringsmedel är säkrast vid astma?', a: 'Parfymfria, oparfymerade produkter med enzymatisk rengöring. Bikarbonat och ättika har inga flyktiga kemiska ämnen som irriterar luftvägarna. Undvik starkt doftande rengöringsprodukter, klorin och produkter som innehåller ammoniak eller formaldehyd.' },
  { q: 'Ska jag bära mask när jag städar?', a: 'En P2-mask (FFP2) filtrerar 94 procent av partiklar och minskar exponering markant. Det är särskilt viktigt vid dammsugning, bäddning och tömning av dammsugarpåsen.' },
  { q: 'Hur snart kan jag gå in i ett rum jag just dammsugit?', a: 'Vänta minst 20 till 30 minuter. Dammsugning uppvirvlar en del damm, särskilt om dammsugaren inte är helt tätad. Under den tiden sjunker de flesta partiklar till marken igen.' },
  { q: 'Kan jag be någon annan städa åt mig under en astmaattack?', a: 'Absolut. Under en pågående astmaperiod är det klokt att delegera städning, särskilt dammsugning och bäddning. Frisk luft och vila är prioritet.' },
];
