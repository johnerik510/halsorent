<ArticleLayout
  title="Städa när du har astma: råd som faktiskt hjälper | Hälsorent"
  description="Städning kan utlösa astmaanfall. Rätt teknik, rätt timing och rätt skydd minskar risken utan att hemmet blir ostädat."
  heroImage="/images/articles/astma.webp"
  heroAlt="Person som städar med mask och handskar för att skydda luftvägarna"
  publishDate="2026-04-29"
  readingTime={7}
