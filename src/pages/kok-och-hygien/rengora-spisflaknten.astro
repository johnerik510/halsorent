const faqItems = [
  { q: 'Hur vet jag om min spisfläkt har kolfilter eller frånluftsfläkt?', a: 'Frånluftsfläkt (ventilerad): har ett rör som går ut genom vägg eller tak. Kolfilterfläkt (cirkulerande): har inget rör, luften filtreras och recirkuleras. Kolfilter behöver bytas, inte bara rengöras. Kontrollera modellens manual.' },
  { q: 'Kan man diska fettfiltret i diskmaskin?', a: 'Ja, de flesta metalliska fettfilter (aluminiumfilter) tål diskmaskin, 60-gradersprogram. Det är det enklaste sättet att rengöra dem. Kontrollera i manualen. Gamla filter kan missfärgas men funktionen påverkas inte.' },
  { q: 'Hur länge håller ett kolfilter?', a: 'Vid normal matlagning 3 till 6 månader. Vid intensiv matlagning med mycket fett och kryddor kortare. Kolfilter kan inte rengöras, aktiv kol mättas och tappar absorptionsförmåga. Byt kolfilter vid sämre luktabsorption, inte på fast schema.' },
  { q: 'Kan igensatt fläkt orsaka brand?', a: 'Ja. Inbränt fett i fläkten och i kanalerna är brandfarligt. En spisfläkt som inte rengörs regelbundet är en av de vanligaste orsakerna till köksbränder. Rengör fettfiltret minst var tredje månad.' },
