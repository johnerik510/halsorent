const faqItems = [
  { q: 'Hur farligt är hög koldioxid inomhus?', a: 'Vid normala inomhusnivåer (400 till 1 500 ppm) är koldioxid inte direkt farligt, men det påverkar kognition och välbefinnande märkbart. Studier visar att kognitionsförmågan minskar med 15 procent vid 1 000 ppm och med 50 procent vid 2 500 ppm jämfört med utomhusluft på 420 ppm.' },
  { q: 'Hur många ppm är normalt utomhus?', a: 'Utomhusluft i städer innehåller 410 till 430 ppm CO₂. I naturen utan biltrafik är det 400 till 415 ppm. Under 700 ppm anses utmärkt för inomhusmiljöer. 700 till 1 000 ppm är acceptabelt, över 1 000 är ett tecken på otillräcklig ventilation.' },
  { q: 'Hjälper växter mot koldioxid?', a: 'Inte märkbart. Växter absorberar CO₂ via fotosyntes men i mycket liten mängd jämfört med det du andas ut. En genomsnittlig människa andas ut 200 liter CO₂ per timme. Du skulle behöva ett par hundra stora växter för att kompensera en person. Ventilation är den enda effektiva åtgärden.' },
  { q: 'Vad kostar en CO₂-mätare?', a: 'En grundläggande CO₂-mätare med NDIR-sensor (korrektare teknik) kostar 400 till 800 kronor. Billigare varianter använder elektrisk sensor och är opålitliga. Märken som Aranet4, CO2meter och SCD40-baserade modeller brukar rekommenderas.' },
  { q: 'Räcker det med friskluftventiler?', a: 'Friskluftventiler i fönsterkarmar tillför frisk luft passivt men beror helt på temperaturskillnaden inne/ute. På sommaren, när trycket är lika på båda sidor, tillför de lite luft. De är ett bra komplement men inte en fullständig lösning vid hög belastning (sovrum med stängd dörr).' },
];
---
<ArticleLayout
  title="Koldioxid inomhus: mäta, förstå och sänka CO₂-halten hemma | Hälsorent"
  description="Hög CO₂-halt i hemmet ger trötthet, huvudvärk och sämre sömn. Hur du mäter koldioxid, tolkar värdena och åtgärdar problemet med ventilation."
  heroImage="/images/articles/koldioxid.webp"
  heroAlt="CO2-mätare på ett nattduksbord i ett sovrum"
