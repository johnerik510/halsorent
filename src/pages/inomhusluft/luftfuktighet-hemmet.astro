const toc = [
  { id: 'optimal-niva', label: 'Optimal nivå' },
  { id: 'for-torr', label: 'Om luften är för torr' },
  { id: 'for-fuktig', label: 'Om luften är för fuktig' },
  { id: 'mata', label: 'Hur du mäter' },
  { id: 'luftfuktare', label: 'Luftfuktare' },
  { id: 'avfuktare', label: 'Avfuktare' },
  { id: 'rum-for-rum', label: 'Rum för rum' },
  { id: 'faq', label: 'Vanliga frågor' },
