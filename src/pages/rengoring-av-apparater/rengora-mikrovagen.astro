const faqItems = [
  { q: 'Kan man använda diskmedel i mikrovågsugnen?', a: 'Ja, en liten mängd diskmedel utspädd i varmt vatten fungerar bra på insidan. Skölj väl med fuktig duk efteråt. Undvik starka slipmedel och skursvampar på insidan som kan repa lacken.' },
  { q: 'Varför luktar det bränt i mikrovågsugnen trots att den är ren?', a: 'Lukt kan sitta i ventilationsöppningarna och i fettfiltret om modellen har ett sådant. Det kan även vara matrester bakom den inre rutan eller i glänsen runt dörren. Aktivt kol i ett glas vatten som körs i mikron kan absorbera lukter, liksom en skål med citronsaft.' },
  { q: 'Kan man ta bort mikrovågsugnens inre platta och diska den?', a: 'Ja, glasplattan i botten är alltid avtagbar och diskmaskins- och handdiskbar. Det är det enklaste sättet att rengöra den ordentligt. Rullringen (plastringen under plattan) kan också tas ur och diskas.' },
  { q: 'Hur rensar man en igensatt ventilationstrumma i mikrovågsugnen?', a: 'Mikrovågsugnar som sitter ovanför spisen (hood-typ) har fettfilter som ska rengöras eller bytas var 3 till 6 månad. De flesta kan diskas i diskmaskin. Resterande ventilationsöppningar rengörs med fuktig duk och en mjuk borste, aldrig med vätska direkt i öppningarna.' },
  { q: 'Hur sällan kan man rengöra mikrovågsugnen?', a: 'Minst en gång i månaden om den används dagligen. Tre gånger per år om den används sällan. Mikrovågsugnar med inbränt fett på väggarna kan ge ifrån sig rök och avger partiklar vid uppvärmning. Konsekvent rengöring är hygienisk och förlänger apparatens livslängd.' },
];
---
<ArticleLayout
  title="Rengöra mikrovågsugnen: ångmetoden och hur du tar bort inbränt | Hälsorent"
