---
import BaseLayout from '../layouts/BaseLayout.astro';
import { clusters, articles } from '../data/articles';

const published = articles.filter(a => a.published);
const sorted = [...published].sort((a, b) => {
  const da = a.updateDate ?? a.publishDate;
  const db = b.updateDate ?? b.publishDate;
  return db.localeCompare(da);
});

const featured = sorted.slice(0, 9);

const formatDate = (d: string) =>
  new Date(d).toLocaleDateString('sv-SE', { year: 'numeric', month: 'short', day: 'numeric' });
---
<BaseLayout
  title="Hälsorent.se — städning och inomhusmiljö för din hälsa"
  description="Oberoende guider om allergivänlig städning, kemikaliefri rengöring, inomhusluft och mögel. Faktabaserade råd för ett friskare hem."
>

  <!-- Kompakt varumärkeshuvud utan hero-bild -->
  <div class="bg-primary-dark text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-14">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-3 py-1 text-xs font-semibold text-white/80 uppercase tracking-wider mb-4 font-sans">
          <span class="w-1.5 h-1.5 bg-accent rounded-full"></span>
          Oberoende guide 2026
        </div>
        <h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold mb-4 leading-tight">Städa för hälsans skull.</h1>
        <p class="text-white/80 text-lg leading-relaxed mb-6 font-sans max-w-xl">Faktabaserade guider om allergivänlig städning, kemikaliefri rengöring, inomhusluft och mögel.</p>
        <div class="flex flex-wrap gap-3">
          <span class="inline-flex items-center gap-1.5 bg-white/10 border border-white/15 rounded-lg px-3 py-1.5 text-sm font-sans text-white/90">
            <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            {published.length} faktagranskade guider
          </span>
          <span class="inline-flex items-center gap-1.5 bg-white/10 border border-white/15 rounded-lg px-3 py-1.5 text-sm font-sans text-white/90">
            <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Granskade av legitimerad sjuksköterska
          </span>
        </div>
      </div>
    </div>
  </div>

  <!-- Senaste guider med datum -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex items-baseline justify-between mb-8">
      <div>
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-primary-dark">Senaste guider</h2>
        <p class="text-text-light text-sm mt-1 font-sans">Uppdateras löpande med ny forskning och verifierade råd</p>
      </div>
      <a href="#amnen" class="text-sm font-semibold text-accent-dark hover:text-primary transition-colors font-sans hidden sm:inline">Alla ämnen &rarr;</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {featured.map((a) => (
        <article class="bg-white border border-border rounded-xl overflow-hidden hover:shadow-md hover:border-primary transition-all group">
          <a href={a.url} class="block" aria-label={a.title}>
            <div class="aspect-[16/9] overflow-hidden bg-bg-alt">
              <img
                src={a.hero}
                alt={a.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
                width="800"
                height="450"
              />
            </div>
          </a>
          <div class="p-5">
            <div class="flex items-center justify-between mb-2">
              <span class="text-xs uppercase tracking-widest text-accent-dark font-semibold font-sans">{a.category}</span>
              <time
                datetime={a.updateDate ?? a.publishDate}
                class="text-xs text-text-lighter font-sans"
              >{formatDate(a.updateDate ?? a.publishDate)}</time>
            </div>
            <h3 class="font-heading text-base font-bold text-text mb-2 leading-snug">
              <a href={a.url} class="hover:text-primary transition-colors">{a.title}</a>
            </h3>
            <p class="text-sm text-text-light leading-relaxed mb-4 font-sans line-clamp-3">{a.excerpt}</p>
            <a href={a.url} class="text-sm font-semibold text-accent-dark hover:text-primary transition-colors font-sans">
              {a.title.split(':')[0]} &rarr;
            </a>
          </div>
        </article>
      ))}
    </div>
    <div class="mt-6 text-center sm:hidden">
      <a href="#amnen" class="text-sm font-semibold text-accent-dark hover:text-primary transition-colors font-sans">Alla ämnen &rarr;</a>
    </div>
  </section>

  <!-- Bläddra efter ämne -->
  <section id="amnen" class="bg-bg-alt py-12 border-t border-border">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-8">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-primary-dark mb-1">Bläddra efter ämne</h2>
        <p class="text-text-light text-sm font-sans">Sex ämnesområden om hur hemmet påverkar din hälsa.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {clusters.map((c) => (
          <a
            href={c.url}
            class="group flex flex-col gap-3 p-5 bg-white border border-border rounded-xl hover:border-primary hover:shadow-sm transition-all"
            aria-label={`${c.label}: ${c.description}`}
          >
            <h3 class="font-heading text-base font-bold text-primary-dark group-hover:text-primary transition-colors">{c.label}</h3>
            <p class="text-sm text-text-light leading-relaxed flex-1 font-sans">{c.description}</p>
            <span class="text-sm text-accent-dark font-semibold group-hover:text-primary transition-colors font-sans">
              Guider om {c.shortLabel.toLowerCase()} &rarr;
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Trust-signaler -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 border-t border-border">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <div class="text-lg font-heading font-bold text-primary mb-2">Verifierade fakta</div>
        <p class="text-sm text-text-light leading-relaxed font-sans">Råd kontrolleras mot Folkhälsomyndigheten, Astma- och Allergiförbundet och publicerad forskning, inte mot tillverkares reklamtext.</p>
      </div>
      <div>
        <div class="text-lg font-heading font-bold text-primary mb-2">Klinisk erfarenhet</div>
        <p class="text-sm text-text-light leading-relaxed font-sans">Karin Holm har 10 år bakom sig som sjuksköterska inom allergi och lungsjukdomar. Det syns i råden: konkret, nyanserat, utan onödig skrämselpropaganda.</p>
      </div>
      <div>
        <div class="text-lg font-heading font-bold text-primary mb-2">Ärliga bedömningar</div>
        <p class="text-sm text-text-light leading-relaxed font-sans">Vi säger ifrån när ett problem kräver specialist. Hälsorent tjänar inget på att du köper dyra produkter du inte behöver.</p>
      </div>
    </div>
  </section>

  <!-- Redaktör -->
  <section class="bg-bg-alt border-t border-border py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl flex flex-col sm:flex-row items-start gap-6">
        <img
          src="/images/authors/karin-holm.webp"
          alt="Karin Holm, chefredaktör på Hälsorent"
          width="120"
          height="120"
          class="w-20 h-20 sm:w-24 sm:h-24 rounded-full object-cover flex-shrink-0 border-2 border-border shadow-sm"
          loading="lazy"
        />
        <div>
          <div class="text-xs uppercase tracking-widest text-accent-dark font-semibold mb-1 font-sans">Chefredaktör</div>
          <h2 class="font-heading text-xl font-bold text-primary-dark mb-2">Karin Holm</h2>
          <p class="text-text-light leading-relaxed mb-3 font-serif text-sm">Legitimerad sjuksköterska med specialisering mot allergi och lungsjukdomar. 10 år på allergiavdelning, sedan rådgivare åt Astma- och Allergiförbundet. Startade hälsorent.se för att ge svenska hushåll ärliga, faktabaserade råd om hur hemmet påverkar hälsan.</p>
          <a href="/redaktionen/" class="inline-flex items-center gap-1 text-sm font-semibold text-accent-dark hover:text-primary transition-colors font-sans">
            Om redaktionen &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
