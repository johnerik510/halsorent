---
import BaseLayout from '../layouts/BaseLayout.astro';
import { clusters, articles } from '../data/articles';

const published = articles.filter(a => a.published);
const sorted = [...published].sort((a, b) => {
  const da = a.updateDate ?? a.publishDate;
  const db = b.updateDate ?? b.publishDate;
  return db.localeCompare(da);
});

const featured   = sorted[0];
const secondary  = sorted.slice(1, 3);
const rest       = sorted.slice(3, 12);

const formatDate = (d: string) =>
  new Date(d).toLocaleDateString('sv-SE', { year: 'numeric', month: 'short', day: 'numeric' });
---
<BaseLayout
  title="Hälsorent.se, städning och inomhusmiljö för din hälsa"
  description="Oberoende guider om allergivänlig städning, kemikaliefri rengöring, inomhusluft och mögel. Faktabaserade råd för ett friskare hem."
>

  <!-- Toppnyhet: stor featured + 2 sekundära -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-6">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_340px] gap-6">

      <!-- Stor featured -->
      <article class="group relative">
        <a href={featured.url} class="block">
          <div class="aspect-[16/9] overflow-hidden rounded-xl bg-bg-alt">
            <img
              src={featured.hero}
              alt={featured.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="eager"
              fetchpriority="high"
              width="800"
              height="450"
            />
          </div>
          <span class="sr-only">{featured.title}</span>
        </a>
        <div class="mt-4">
          <div class="flex items-center gap-3 mb-2">
            <a href={featured.categoryUrl} class="text-xs font-bold uppercase tracking-widest text-accent-dark hover:text-primary transition-colors font-sans">{featured.category}</a>
            <time datetime={featured.updateDate ?? featured.publishDate} class="text-xs text-text-lighter font-sans">{formatDate(featured.updateDate ?? featured.publishDate)}</time>
          </div>
          <h2 class="font-heading text-2xl sm:text-3xl font-bold text-text leading-snug mb-2">
            <a href={featured.url} class="hover:text-primary transition-colors">{featured.title.split(':')[0]}</a>
          </h2>
          <p class="text-text-light leading-relaxed font-sans text-sm sm:text-base line-clamp-2">{featured.excerpt}</p>
        </div>
      </article>

      <!-- 2 sekundära staplades -->
      <div class="flex flex-col gap-5 lg:border-l lg:border-border lg:pl-6">
        {secondary.map(a => (
          <article class="group flex gap-4">
            <a href={a.url} class="flex-shrink-0">
              <div class="w-24 h-24 sm:w-28 sm:h-28 overflow-hidden rounded-lg bg-bg-alt">
                <img
                  src={a.hero}
                  alt={a.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="eager"
                  width="200"
                  height="200"
                />
              </div>
              <span class="sr-only">{a.title}</span>
            </a>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <a href={a.categoryUrl} class="text-xs font-bold uppercase tracking-widest text-accent-dark hover:text-primary transition-colors font-sans truncate">{a.category}</a>
              </div>
              <h3 class="font-heading text-base font-bold text-text leading-snug mb-1">
                <a href={a.url} class="hover:text-primary transition-colors">{a.title.split(':')[0]}</a>
              </h3>
              <time datetime={a.updateDate ?? a.publishDate} class="text-xs text-text-lighter font-sans">{formatDate(a.updateDate ?? a.publishDate)}</time>
            </div>
          </article>
        ))}
        <!-- Redaktörspresentation kompakt -->
        <div class="mt-auto pt-5 border-t border-border flex items-center gap-3">
          <img src="/images/authors/karin-holm.webp" alt="Karin Holm" width="40" height="40" class="w-10 h-10 rounded-full object-cover flex-shrink-0 border border-border" loading="lazy" />
          <div>
            <div class="text-xs font-semibold text-text font-sans">Karin Holm, legitimerad sjuksköterska</div>
            <a href="/redaktionen/" class="text-xs text-accent-dark hover:text-primary font-sans">Om redaktionen &rarr;</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="border-border max-w-6xl mx-auto px-4 sm:px-6 lg:px-8" />

  <!-- Resten av artiklarna i grid -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-baseline justify-between mb-6">
      <h2 class="font-heading text-lg font-bold text-primary-dark uppercase tracking-wide font-sans">Senaste guider</h2>
      <span class="text-xs text-text-lighter font-sans">{published.length} faktagranskade guider</span>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-8">
      {rest.map(a => (
        <article class="group flex gap-4 sm:flex-col sm:gap-0">
          <a href={a.url} class="flex-shrink-0 sm:flex-shrink sm:block sm:mb-3">
            <div class="w-24 h-24 sm:w-full sm:aspect-[16/9] overflow-hidden rounded-lg bg-bg-alt">
              <img
                src={a.hero}
                alt={a.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
                width="800"
                height="450"
              />
            </div>
            <span class="sr-only">{a.title}</span>
          </a>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <a href={a.categoryUrl} class="text-xs font-bold uppercase tracking-widest text-accent-dark hover:text-primary transition-colors font-sans">{a.category}</a>
              <time datetime={a.updateDate ?? a.publishDate} class="text-xs text-text-lighter font-sans ml-auto sm:ml-0">{formatDate(a.updateDate ?? a.publishDate)}</time>
            </div>
            <h3 class="font-heading text-sm sm:text-base font-bold text-text leading-snug mb-1">
              <a href={a.url} class="hover:text-primary transition-colors">{a.title.split(':')[0]}</a>
            </h3>
            <p class="text-xs sm:text-sm text-text-light leading-relaxed font-sans line-clamp-2 hidden sm:block">{a.excerpt}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Ämnesöversikt -->
  <section id="amnen" class="bg-bg-alt border-t border-border py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-lg font-bold text-primary-dark uppercase tracking-wide mb-5 font-sans">Bläddra efter ämne</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
        {clusters.map(c => (
          <a
            href={c.url}
            class="group flex flex-col gap-2 p-4 bg-white border border-border rounded-xl hover:border-primary hover:shadow-sm transition-all"
          >
            <h3 class="font-heading text-sm font-bold text-primary-dark group-hover:text-primary transition-colors leading-tight">{c.label}</h3>
            <span class="text-xs text-accent-dark font-semibold group-hover:text-primary transition-colors font-sans">
              {c.label} guider &rarr;
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Trust-rad -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 border-t border-border">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-sm">
      <div class="flex gap-3">
        <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        <div>
          <div class="font-semibold text-text font-sans mb-0.5">Verifierade fakta</div>
          <p class="text-text-lighter leading-relaxed font-sans">Kontrollerade mot Folkhälsomyndigheten och publicerad forskning.</p>
        </div>
      </div>
      <div class="flex gap-3">
        <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        <div>
          <div class="font-semibold text-text font-sans mb-0.5">Klinisk erfarenhet</div>
          <p class="text-text-lighter leading-relaxed font-sans">10 år som sjuksköterska inom allergi och lungsjukdomar.</p>
        </div>
      </div>
      <div class="flex gap-3">
        <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        <div>
          <div class="font-semibold text-text font-sans mb-0.5">Ärliga bedömningar</div>
          <p class="text-text-lighter leading-relaxed font-sans">Vi tjänar inget på att du köper produkter du inte behöver.</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
