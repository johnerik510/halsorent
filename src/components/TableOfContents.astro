---
interface TOCItem {
  id: string;
  label: string;
}
interface Props {
  items: TOCItem[];
}
const { items } = Astro.props;
---
<aside class="sticky top-24 bg-bg-alt border border-border rounded-xl p-5 text-sm font-sans" aria-label="Innehållsförteckning">
  <p class="font-semibold text-text uppercase tracking-wider text-xs mb-3">Innehåll</p>
  <ol class="space-y-1.5">
    {items.map((item, i) => (
      <li>
        <a href={`#${item.id}`} class="flex gap-2 items-start text-text-light hover:text-primary transition-colors leading-snug">
          <span class="text-accent-dark font-semibold flex-shrink-0">{i + 1}.</span>
          <span>{item.label}</span>
        </a>
      </li>
    ))}
  </ol>
</aside>
