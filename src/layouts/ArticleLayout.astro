---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AuthorByline from '../components/AuthorByline.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Crumb { label: string; href?: string; }
interface TOCItem { id: string; label: string; }

interface Props {
  title: string;
  description: string;
  heroImage: string;
  heroAlt: string;
  publishDate: string;
  updateDate?: string;
  readingTime?: number;
  breadcrumbs: Crumb[];
  toc?: TOCItem[];
  ogImage?: string;
  category: string;
}

const { title, description, heroImage, heroAlt, publishDate, updateDate, readingTime, breadcrumbs, toc, ogImage, category } = Astro.props;
const h1 = title.split(' | ')[0];

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: `https://hälsorent.se${heroImage}`,
  datePublished: publishDate,
  dateModified: updateDate || publishDate,
  author: {
    '@type': 'Person',
    name: 'Karin Holm',
    url: 'https://hälsorent.se/redaktionen/#karin-holm',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Hälsorent',
    url: 'https://hälsorent.se',
  },
  articleSection: category,
  inLanguage: 'sv-SE',
  mainEntityOfPage: { '@type': 'WebPage', '@id': Astro.url.href },
};
---
<BaseLayout title={title} description={description} ogImage={ogImage || heroImage}>
  <slot name="head" slot="head" />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleSchema)} />

  <div class="reading-progress" id="reading-progress" aria-hidden="true"></div>

  <article>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 pb-10">
      <Breadcrumbs items={breadcrumbs} />

      <div class="lg:grid lg:grid-cols-[1fr_280px] lg:gap-12 mt-4">
        <div>
          <!-- Kategori + rubrik + ingress -->
          <header class="mb-6">
            <a href={breadcrumbs[1]?.href ?? '/'} class="text-xs font-bold uppercase tracking-widest text-accent-dark hover:text-primary transition-colors font-sans">{category}</a>
            <h1 class="font-heading text-3xl sm:text-4xl font-bold text-text leading-tight mt-2 mb-3">{h1}</h1>
            <p class="text-lg text-text-light leading-relaxed font-serif">{description}</p>
          </header>

          <AuthorByline publishDate={publishDate} updateDate={updateDate} readingTime={readingTime} variant="top" />

          <!-- Heroibild inlinead -->
          <figure class="mb-8 -mx-4 sm:mx-0">
            <img
              src={heroImage}
              alt={heroAlt}
              class="w-full sm:rounded-xl object-cover"
              style="aspect-ratio: 16/9; max-height: 480px;"
              loading="eager"
              fetchpriority="high"
              width="1200"
              height="675"
            />
          </figure>

          <div class="prose-article">
            <slot />
          </div>
          <AuthorByline publishDate={publishDate} updateDate={updateDate} readingTime={readingTime} variant="bottom" />
        </div>

        {toc && toc.length > 0 && (
          <aside class="hidden lg:block">
            <TableOfContents items={toc} />
          </aside>
        )}
      </div>
    </div>
  </article>

  <script is:inline>
    (function () {
      var bar = document.getElementById('reading-progress');
      if (!bar) return;
      function update() {
        var h = document.documentElement;
        var scrolled = h.scrollTop / (h.scrollHeight - h.clientHeight) * 100;
        bar.style.width = Math.max(0, Math.min(100, scrolled)) + '%';
      }
      window.addEventListener('scroll', update, { passive: true });
      update();
    })();
  </script>
</BaseLayout>
